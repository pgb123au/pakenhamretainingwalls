---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
  noindex?: boolean;
}

const SITE = 'https://pakenhamretainingwalls.com.au';
const PHONE_DISPLAY = '(03) 9003 0223';
const PHONE_TEL = '+61390030223';
const EMAIL = 'quotes@pakenhamretainingwalls.com.au';
const BIZ_NAME = 'Pakenham Retaining Walls';

const { title, description, canonical = SITE + '/', ogType = 'website', noindex = false } = Astro.props;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": SITE + "/#business",
  "name": BIZ_NAME,
  "image": SITE + "/images/og-image.jpg",
  "url": SITE,
  "telephone": PHONE_TEL,
  "priceRange": "$$",
  "description": "Specialist retaining wall and earthworks contractors serving Pakenham, Officer, Berwick and the wider Cardinia Shire. Timber sleeper walls, concrete sleeper walls, masonry block walls, excavation and site preparation.",
  "areaServed": [
    { "@type": "City", "name": "Pakenham", "containedInPlace": { "@type": "AdministrativeArea", "name": "Cardinia Shire" } },
    { "@type": "City", "name": "Officer" },
    { "@type": "City", "name": "Berwick" },
    { "@type": "City", "name": "Beaconsfield" },
    { "@type": "City", "name": "Cardinia" },
    { "@type": "City", "name": "Pakenham South" },
    { "@type": "City", "name": "Officer South" },
    { "@type": "City", "name": "Garfield" },
    { "@type": "City", "name": "Drouin" }
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Pakenham",
    "addressRegion": "VIC",
    "postalCode": "3810",
    "addressCountry": "AU"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -38.0727,
    "longitude": 145.4830
  },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "07:00",
    "closes": "18:00"
  }],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Retaining Wall Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Timber Sleeper Retaining Walls" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Concrete Sleeper Retaining Walls" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Masonry Block Retaining Walls" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Excavation & Earthworks" }}
    ]
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": SITE + "/#website",
  "url": SITE + "/",
  "name": BIZ_NAME,
  "inLanguage": "en-AU",
  "publisher": { "@id": SITE + "/#business" }
};
---
<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>
  <meta name="robots" content={noindex ? "noindex, follow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}>
  <meta name="theme-color" content="#14304a">

  <meta property="og:type" content={ogType}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:locale" content="en_AU">
  <meta property="og:site_name" content={BIZ_NAME}>
  <meta property="og:image" content={SITE + "/images/og-image.jpg"}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content={BIZ_NAME}>
  <meta name="twitter:image" content={SITE + "/images/og-image.jpg"}>

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>

  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='5' fill='%2314304a'/><text x='16' y='22' text-anchor='middle' fill='%23d97706' font-family='Georgia' font-size='18' font-weight='bold'>P</text></svg>">

  <!-- Google Search Console verification (URL-prefix backup; primary verification via DNS TXT on sc-domain property) -->
  <meta name="google-site-verification" content="tlkPdKlIChAsk6Lzxk6ZpDrQ7PB0IVvznLSVWwnlfHY">

  <!-- Google Analytics 4 (Pakenham Retaining Walls property 536867630) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-6VLK7MRKVV"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-6VLK7MRKVV', {
      'send_page_view': true,
      'anonymize_ip': true
    });
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <slot name="head" />
</head>
<body>
  <div class="top-bar">
    <span>Free quotes &middot; Servicing Pakenham &amp; the Cardinia Shire &middot; Call <a href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a></span>
  </div>

  <header class="site-header">
    <div class="nav-wrap">
      <a class="brand" href="/" aria-label="Pakenham Retaining Walls home">
        <small>Pakenham &middot; Cardinia Shire</small>
        Pakenham Retaining Walls
      </a>
      <ul class="nav-links">
        <li><a href="/services/timber-retaining-walls/">Timber</a></li>
        <li><a href="/services/concrete-sleeper-walls/">Concrete</a></li>
        <li><a href="/services/block-retaining-walls/">Block</a></li>
        <li><a href="/services/excavation-earthworks/">Earthworks</a></li>
        <li><a href="/cardinia/">Areas</a></li>
      </ul>
      <a class="nav-cta" href="/quote/">Free Quote</a>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div>
        <h4>Pakenham Retaining Walls</h4>
        <p style="margin-bottom: 0.75rem;">Specialist retaining wall builders &amp; earthworks for the Cardinia Shire.</p>
        <p style="margin-bottom: 0.5rem;"><strong style="color:#fff;">Phone:</strong> <a href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a></p>
        <p style="margin-bottom: 0.5rem;"><strong style="color:#fff;">Hours:</strong> Mon&ndash;Sat 7am&ndash;6pm</p>
        <p><strong style="color:#fff;">Service area:</strong> Pakenham VIC 3810 &amp; surrounds</p>
      </div>
      <div>
        <h4>Services</h4>
        <ul>
          <li><a href="/services/timber-retaining-walls/">Timber sleeper walls</a></li>
          <li><a href="/services/concrete-sleeper-walls/">Concrete sleeper walls</a></li>
          <li><a href="/services/block-retaining-walls/">Block &amp; masonry walls</a></li>
          <li><a href="/services/excavation-earthworks/">Excavation &amp; earthworks</a></li>
        </ul>
      </div>
      <div>
        <h4>Service Areas</h4>
        <ul>
          <li><a href="/officer/">Officer</a></li>
          <li><a href="/berwick/">Berwick</a></li>
          <li><a href="/beaconsfield/">Beaconsfield</a></li>
          <li><a href="/cardinia/">Cardinia Shire</a></li>
        </ul>
      </div>
      <div>
        <h4>Resources</h4>
        <ul>
          <li><a href="/pricing/">Pricing guide</a></li>
        </ul>
      </div>
    </div>
    <p class="footer-bottom">
      &copy; {new Date().getFullYear()} {BIZ_NAME}. ABN registered. Free quotes throughout the Cardinia Shire.
    </p>
  </footer>

  <a class="mobile-phone" href={`tel:${PHONE_TEL}`} aria-label={`Call ${PHONE_DISPLAY}`}>
    <span aria-hidden="true">&#9742;</span> Call {PHONE_DISPLAY}
  </a>
</body>
</html>
