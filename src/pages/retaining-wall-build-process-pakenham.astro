    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="cta-block">
        <h2>Get a fixed-price quote for your Pakenham retaining wall.</h2>
        <p>Free on-site assessment. Engineering and drainage included in the scope, not added later.</p>
        <div class="hero-actions" style="justify-content:center;">
          <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call (03) 9003 0108</a>
          <a class="btn btn-ghost" href="/quote/">Request a free quote</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
